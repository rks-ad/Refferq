# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/refferq"

# Email Service (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Refferq <onboply@resend.dev>"
